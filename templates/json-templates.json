{"username-menu":"<div class=\"fixed bottom-20 left-0\" style=\"z-index: 99999\">\n    <div style=\"\n        display: flex;\n        align-items: center;\n        gap: 8px;\n        padding: 10px 12px;\n        background: rgba(255, 255, 255, 0.94);\n        border: 1px solid rgba(0, 0, 0, 0.08);\n        border-radius: 12px;\n        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);\n        backdrop-filter: blur(6px);\n      \">\n      <input placeholder=\"Set new username\" v-model=\"settings.menu.newUsername\" style=\"\n          height: 36px;\n          min-width: 220px;\n          border: 1px solid #d1d5db;\n          border-radius: 10px;\n          padding: 0 12px;\n          outline: none;\n          font-size: 14px;\n          color: #111827;\n          background: #fff;\n        \" @keyup.enter=\"setUsername()\">\n      <button @click=\"setUsername()\" style=\"\n          height: 36px;\n          width: 36px;\n          border: none;\n          border-radius: 10px;\n          background: #111827;\n          color: #fff;\n          cursor: pointer;\n          display: flex;\n          align-items: center;\n          justify-content: center;\n        \">\n        <i class=\"fas fa-save\"></i>\n      </button>\n    </div>\n  </div>"}